{
    "name": "sd-mail-service-backend",
    "version": "0.1.0",
    "description": "SalesDuo standalone notification / lifecycle-email service — backend (api + worker + scheduler)",
    "main": "dist/server.js",
    "scripts": {
        "dev": "npm run db:ready && npm run migrate:up && npm run seed && npm run dev:api",
        "dev:api": "cross-env SD_PROCESS=api ts-node-dev --respawn --transpile-only src/server.ts",
        "dev:worker": "npm run db:ready && cross-env SD_PROCESS=worker ts-node-dev --respawn --transpile-only src/worker.ts",
        "dev:scheduler": "npm run db:ready && cross-env SD_PROCESS=scheduler ts-node-dev --respawn --transpile-only src/scheduler.ts",
        "db:ready": "cross-env SD_PROCESS=wait ts-node --transpile-only src/scripts/wait-for-db.ts",
        "build": "tsc",
        "start": "npm run migrate:up && node dist/server.js",
        "start:worker": "node dist/worker.js",
        "start:scheduler": "node dist/scheduler.js",
        "seed": "cross-env SD_PROCESS=seed ts-node --transpile-only src/seeds/index.ts",
        "seed:prod": "node dist/seeds/index.js",
        "migrate:create": "npx sequelize-cli migration:generate --name",
        "migrate:up": "npx sequelize-cli db:migrate",
        "migrate:down": "npx sequelize-cli db:migrate:undo",
        "openapi": "cross-env SD_PROCESS=openapi ts-node --transpile-only src/openapi/generate.ts",
        "lint": "eslint src",
        "clean": "rimraf dist && rimraf node_modules",
        "test": "cross-env NODE_ENV=test PGDATABASE=sd_mail_test jest --runInBand"
    },
    "dependencies": {
        "@aws-sdk/client-ses": "^3.700.0",
        "bcryptjs": "^3.0.3",
        "bullmq": "^5.34.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.0.0",
        "ioredis": "^5.4.2",
        "jsonwebtoken": "^9.0.2",
        "liquidjs": "^10.19.0",
        "morgan": "^1.10.0",
        "nodemailer": "^6.9.16",
        "pg": "^8.13.1",
        "pg-hstore": "^2.3.4",
        "sequelize": "^6.37.5",
        "sequelize-cli": "^6.6.2",
        "uuid": "^11.0.3",
        "winston": "^3.17.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.8",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.17.10",
        "@types/nodemailer": "^6.4.17",
        "@types/pg": "^8.11.10",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^10.0.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.17.0",
        "globals": "^15.14.0",
        "jest": "^29.7.0",
        "rimraf": "^6.0.1",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.18.1"
    }
}
