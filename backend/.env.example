# ---- sd-mail-service backend — environment template ----
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# In production these come from a secret manager, not a file.

# ---- Dedicated standalone ports (no overlap with core-platform / studio) ----
# api 3110 · admin 5180 · postgres 5442 · redis 6389 · mailhog SMTP 1026 / UI 8026
# These are HOST-mode values. docker-compose overrides the connection vars with the
# in-container service addresses (postgres:5432, redis:6379, mailhog:1025).

# Runtime
NODE_ENV=development
PORT=3110
LOG_LEVEL=debug
# Public base URL of this service (used to build unsubscribe links)
PUBLIC_URL=http://localhost:3110
# Serve the built admin SPA from the api (single-container). Auto-on in production.
# Leave false in dev — the admin runs on its own Vite server (:5180).
SERVE_ADMIN=false
# CORS allowlist (prod only; comma-separated browser origins). Dev reflects any origin.
# e.g. CORS_ORIGINS=https://mail-admin.salesduo.com
CORS_ORIGINS=

# Postgres (same var names as sequelize-cli / core-platform)
PGHOST=localhost
PGPORT=5442
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=sd_mail
# Optional: PEM string for RDS SSL in prod (else the RDS CA bundle in the image is used)
# DB_SSL_CA=

# Redis (BullMQ queues + scheduler locks)
REDIS_URL=redis://localhost:6389
# REDIS_PASSWORD=

# Email transport: "smtp" or "ses"
EMAIL_TRANSPORT=smtp
# SMTP (dev: point at Mailhog on 1026; prod: real SMTP/SES SMTP creds)
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USER=
SMTP_PASS=
# Global fallback From (products override with their own from_email)
SMTP_FROM="SalesDuo <no-reply@salesduo.com>"
# SES (when EMAIL_TRANSPORT=ses) — AWS creds via standard AWS_* env / instance role
SES_REGION=us-east-1
# Optional: restrict the /webhooks/ses (SNS bounce/complaint) endpoint to one topic ARN
# SES_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ses-feedback

# Default superadmin (seeded on `npm run seed`). CHANGE in production.
ADMIN_EMAIL=admin@salesduo.com
ADMIN_PASSWORD=admin12345

# Secrets (generate strong random values; required in production)
# Signs the admin session JWT (httpOnly cookie).
ADMIN_SESSION_SECRET=dev-admin-session-secret-change-me
# Signs one-click unsubscribe tokens (the public /u/:token links).
UNSUB_SECRET=dev-unsubscribe-secret-change-me
# Shared service key for ALL producer calls (X-Service-Key): /internal/events, /messages, /email/send.
INTERNAL_API_KEY=dev-internal-api-key-change-me
